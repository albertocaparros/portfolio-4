{
	"$schema": "https://biomejs.dev/schemas/2.2.0/schema.json",
	"files": {
		"ignoreUnknown": true,
		"includes": [
			"src/**",
			"!**/types.generated.d.ts",
			"public/lang/**",
			"astro.config.mjs",
			"tailwind.config.cjs",
			"tsconfig.json",
			"package.json"
		]
	},
	"formatter": {
		"enabled": true,
		"indentWidth": 2,
		"lineEnding": "lf"
	},
	"javascript": {
		"formatter": {
			"quoteStyle": "single",
			"semicolons": "always",
			"trailingCommas": "es5"
		}
	},
	"json": {
		"formatter": {
			"trailingCommas": "none"
		}
	},
	"linter": {
		"enabled": true,
		"rules": {
			"recommended": true,
			"a11y": {
				"noSvgWithoutTitle": "off",
				"useValidAnchor": "off"
			},
			"correctness": {
				"useExhaustiveDependencies": "off"
			},
			"style": {
				"useFilenamingConvention": "off"
			},
			"suspicious": {
				"noArrayIndexKey": "off"
			}
		}
	},
	"overrides": [
		{
			"includes": ["**/*.astro"],
			"linter": {
				"rules": {
					"correctness": {
						"noUnusedImports": "off",
						"noUnusedVariables": "off"
					},
					"style": {
						"useImportType": "off"
					}
				}
			}
		}
	]
}
